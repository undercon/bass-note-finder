<Window x:Class="BassNoteFinder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bass Note Finder" Height="750" Width="1050"
        Icon="Assets/AppIcon.png"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E" Foreground="White"
        FontFamily="Segoe UI" FontSize="14"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/DarkComboBoxResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ContentControl Grid.Row="0" x:Name="MainContent"/>

        <Border Grid.Row="1" BorderBrush="#333" BorderThickness="1" CornerRadius="8"
                Background="#2A2A2A" Padding="12" Margin="15,0,15,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="45"/>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Input:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox Grid.Column="1" x:Name="InputCombo" Width="240"
                          SelectionChanged="InputCombo_SelectionChanged"
                          Style="{StaticResource DarkInputComboBoxStyle}"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                    <TextBlock Text="Gate" VerticalAlignment="Center" Foreground="#AAA" Margin="0,0,6,0"/>
                    <Slider x:Name="ThresholdSlider" Width="125" Minimum="0.005" Maximum="0.02"
                            SmallChange="0.001" LargeChange="0.002"
                            TickFrequency="0.001" IsSnapToTickEnabled="False"
                            ValueChanged="ThresholdSlider_ValueChanged"/>
                    <TextBlock x:Name="ThresholdValueText" Width="40" Margin="8,0,0,0"
                               VerticalAlignment="Center" Foreground="#CCC" TextAlignment="Right"/>
                </StackPanel>

                <CheckBox Grid.Column="3" x:Name="HarmonicCorrectionCheckBox" Content="Bass Harmonics"
                          VerticalAlignment="Center" Margin="10,0,0,0"
                          Foreground="#CCC"
                          Checked="HarmonicCorrectionCheckBox_Changed"
                          Unchecked="HarmonicCorrectionCheckBox_Changed"/>

                <Button Grid.Column="4" x:Name="ToggleMicBtn" Content="Start Mic"
                        Width="110" Click="ToggleMic_Click" Margin="10,0"
                        Padding="10,6" Background="#0E639C" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"/>

                <Border Grid.Column="5" BorderBrush="#555" BorderThickness="1" 
                        CornerRadius="4" Padding="10,4" Margin="10,0">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="SignalDot" Width="12" Height="12" Margin="0,0,8,0"
                                 VerticalAlignment="Center" Fill="#666" Stroke="#888" StrokeThickness="1"/>
                        <TextBlock Text="Detected: " VerticalAlignment="Center" Foreground="#AAA"/>
                        <TextBlock x:Name="DetectedNoteText" Text="--" 
                                   Width="130" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <CheckBox Grid.Column="6" x:Name="ShowDeviationCheckBox" Content="Deviation"
                          VerticalAlignment="Center" Margin="10,0,0,0"
                          Foreground="#CCC" IsChecked="False"
                          Checked="ShowDeviationCheckBox_Changed"
                          Unchecked="ShowDeviationCheckBox_Changed"/>
            </Grid>
        </Border>
    </Grid>
</Window>
