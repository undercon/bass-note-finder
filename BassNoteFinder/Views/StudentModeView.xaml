<UserControl x:Class="BassNoteFinder.Views.StudentModeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             Loaded="StudentModeView_Loaded">
    <Grid Margin="15,15,15,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="StatusText"
                   Text="Play the shown note."
                   FontSize="13" HorizontalAlignment="Center"
                   Foreground="#AAAAAA" Margin="0,0,0,8"/>

        <UniformGrid Grid.Row="1" Rows="1" Columns="2" Margin="0,0,0,10">
            <Border BorderBrush="#333" BorderThickness="1" Margin="5" CornerRadius="8" Background="#2A2A2A">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Staff" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Margin="0,8,0,4" Foreground="#CCC"/>
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                        <Canvas x:Name="StaffCanvas" Width="500" Height="280" Margin="10" Background="Transparent"/>
                    </ScrollViewer>
                </DockPanel>
            </Border>
            <Border BorderBrush="#333" BorderThickness="1" Margin="5" CornerRadius="8" Background="#2A2A2A">
                <Grid>
                    <DockPanel x:Name="FretboardPanel" Visibility="Hidden">
                        <TextBlock DockPanel.Dock="Top" Text="Fretboard" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" Margin="0,8,0,4" Foreground="#CCC"/>
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                            <Canvas x:Name="FretboardCanvas" Width="720" Height="200" Margin="10" Background="#1E1E1E"/>
                        </ScrollViewer>
                    </DockPanel>
                    <StackPanel x:Name="OverlayPanel" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock x:Name="OverlayIcon" Text="?" FontSize="48" Foreground="#555"
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Name="OverlayText" Text="Play the note to reveal" FontSize="12" Foreground="#777"
                                   HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </UniformGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
            <CheckBox x:Name="ShowNoteNamesCheckBox" Content="Show Note Names"
                      VerticalAlignment="Center" Margin="5,0" Foreground="#CCC"
                      IsChecked="False"
                      Checked="ShowNoteNamesCheckBox_Changed"
                      Unchecked="ShowNoteNamesCheckBox_Changed"/>
            <CheckBox x:Name="IncludeAccidentalsCheckBox" Content="Include Accidentals"
                      VerticalAlignment="Center" Margin="5,0" Foreground="#CCC" IsChecked="False"
                      Checked="IncludeAccidentalsCheckBox_Changed"
                      Unchecked="IncludeAccidentalsCheckBox_Changed"/>
            <CheckBox x:Name="IncludeOctavesCheckBox" Content="Include Octaves"
                      VerticalAlignment="Center" Margin="5,0" Foreground="#CCC" IsChecked="False"
                      Checked="IncludeOctavesCheckBox_Changed"
                      Unchecked="IncludeOctavesCheckBox_Changed"/>
            <CheckBox x:Name="AutoAdvanceCheckBox" Content="Auto Advance"
                      VerticalAlignment="Center" Margin="10,0,5,0" Foreground="#CCC" IsChecked="True"
                      Checked="AutoAdvanceCheckBox_Changed"
                      Unchecked="AutoAdvanceCheckBox_Changed"/>
            <TextBlock Text="Next in" VerticalAlignment="Center" Foreground="#CCC" Margin="5,0,3,0"/>
            <Slider x:Name="NextNoteDelaySlider" Width="110" Minimum="1" Maximum="10" Value="3"
                    TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"
                    ValueChanged="NextNoteDelaySlider_ValueChanged"/>
            <TextBlock x:Name="NextNoteDelayValueText" Text="3s" VerticalAlignment="Center" Foreground="#CCC" Margin="3,0,5,0"/>
            <Button x:Name="RandomBtn" Content="Random" Width="100" Click="RandomBtn_Click"
                    Margin="15,0" Padding="10,6" Background="#2D8C2D" Foreground="White"
                    BorderThickness="0" Cursor="Hand"/>
            <Button x:Name="BackToModeSelectionBtn" Content="Mode Selection" Width="110" Click="BackToModeSelectionBtn_Click"
                    Margin="5,0" Padding="10,6" Background="#555" Foreground="White"
                    BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</UserControl>
