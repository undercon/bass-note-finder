<UserControl x:Class="BassNoteFinder.Views.StudentModeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             Loaded="StudentModeView_Loaded">
    <Grid Margin="15,15,15,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="StatusText"
                    Text="Play the shown note."
                    FontSize="14" HorizontalAlignment="Center"
                    Foreground="#AAAAAA" Margin="0,0,0,8"
                    TextAlignment="Center" TextWrapping="Wrap" MinHeight="24"/>

        <UniformGrid Grid.Row="1" Rows="1" Columns="2" Margin="0,0,0,10">
            <Border BorderBrush="#333" BorderThickness="1" Margin="5" CornerRadius="8" Background="#2A2A2A">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Staff" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Margin="0,8,0,4" Foreground="#CCC"/>
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                        <Canvas x:Name="StaffCanvas" Width="500" Height="280" Margin="10" Background="Transparent"/>
                    </ScrollViewer>
                </DockPanel>
            </Border>
            <Border BorderBrush="#333" BorderThickness="1" Margin="5" CornerRadius="8" Background="#2A2A2A">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Fretboard" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Margin="0,8,0,2" Foreground="#CCC"/>

                    <StackPanel x:Name="OverlayPanel" Grid.Row="1" HorizontalAlignment="Center" Margin="0,4,0,2">
                        <TextBlock x:Name="OverlayIcon" Text="?" FontSize="48" Foreground="#555"
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Name="OverlayText" Text="Play the note to reveal" FontSize="12" Foreground="#777"
                                   HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>

                    <Grid x:Name="FretboardPanel" Grid.Row="2" Visibility="Hidden">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                            <Canvas x:Name="FretboardCanvas" Width="670" Height="200" Margin="10" Background="#1E1E1E"/>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>
        </UniformGrid>

        <WrapPanel Grid.Row="2" HorizontalAlignment="Center" Margin="0,0,0,4">
            <CheckBox x:Name="ShowNoteNamesCheckBox" Content="Show Note Names"
                      VerticalAlignment="Center" Margin="5,4" Foreground="#CCC"
                      IsChecked="False"
                      Checked="ShowNoteNamesCheckBox_Changed"
                      Unchecked="ShowNoteNamesCheckBox_Changed"/>
            <CheckBox x:Name="IncludeAccidentalsCheckBox" Content="Include Accidentals"
                      VerticalAlignment="Center" Margin="5,4" Foreground="#CCC" IsChecked="False"
                      Checked="IncludeAccidentalsCheckBox_Changed"
                      Unchecked="IncludeAccidentalsCheckBox_Changed"/>
            <CheckBox x:Name="IncludeOctavesCheckBox" Content="Include Octaves"
                      VerticalAlignment="Center" Margin="5,4" Foreground="#CCC" IsChecked="False"
                      Checked="IncludeOctavesCheckBox_Changed"
                      Unchecked="IncludeOctavesCheckBox_Changed"/>
            <CheckBox x:Name="AutoAdvanceCheckBox" Content="Auto Advance"
                      VerticalAlignment="Center" Margin="10,4,5,4" Foreground="#CCC" IsChecked="True"
                      Checked="AutoAdvanceCheckBox_Changed"
                      Unchecked="AutoAdvanceCheckBox_Changed"/>
            <TextBlock Text="Next in" VerticalAlignment="Center" Foreground="#CCC" Margin="5,4,3,4"/>
            <Slider x:Name="NextNoteDelaySlider" Width="110" Minimum="1" Maximum="10" Value="3"
                    TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"
                    ValueChanged="NextNoteDelaySlider_ValueChanged"/>
            <TextBlock x:Name="NextNoteDelayValueText" Text="3s" VerticalAlignment="Center" Foreground="#CCC" Margin="3,4,5,4"/>
            <Button x:Name="RandomBtn" Content="Random" Width="110" Click="RandomBtn_Click"
                    Margin="15,4,5,4" Padding="10,6" Background="#2D8C2D" Foreground="White"
                    BorderThickness="0" Cursor="Hand" HorizontalContentAlignment="Center"/>
            <Button x:Name="BackToModeSelectionBtn" Content="Mode Selection" Width="140" Click="BackToModeSelectionBtn_Click"
                    Margin="5,4" Padding="10,6" Background="#555" Foreground="White"
                    BorderThickness="0" Cursor="Hand" HorizontalContentAlignment="Center"/>
        </WrapPanel>
    </Grid>
</UserControl>
